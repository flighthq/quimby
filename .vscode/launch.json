{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Quimby VS Code Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}/apps/vscode", "${workspaceFolder}"],
      "outFiles": ["${workspaceFolder}/apps/vscode/dist/**/*.js"],
      "preLaunchTask": "build quimby-vscode"
    }
  ]
}
