{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "paths": {
      "@quimbyhq/types": ["./packages/types/src/index.ts"],
      "@quimbyhq/core": ["./packages/core/src/index.ts"]
    }
  },
  "include": [
    "apps/*/src/**/*",
    "packages/*/src/**/*",
    "apps/*/*.ts",
    "packages/*/*.ts",
    "*.ts",
    "*.js"
  ]
}
