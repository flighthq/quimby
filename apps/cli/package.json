{
  "name": "quimby",
  "version": "0.2.0",
  "description": "Run AI agents in isolated agents, ship their work as reviewable packs",
  "license": "MIT",
  "type": "module",
  "bin": {
    "quimby": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "check": "eslint src",
    "clean": "rm -rf dist",
    "start": "node dist/cli.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "@quimbyhq/errors": "*",
    "@quimbyhq/git": "*",
    "@quimbyhq/handoff": "*",
    "@quimbyhq/launch": "*",
    "@quimbyhq/paths": "*",
    "@quimbyhq/reporter": "*",
    "@quimbyhq/runtime-profile": "*",
    "@quimbyhq/runtimes": "*",
    "@quimbyhq/server": "*",
    "@quimbyhq/session": "*",
    "@quimbyhq/status": "*",
    "@quimbyhq/template": "*",
    "@quimbyhq/transport": "*",
    "@quimbyhq/types": "*",
    "@quimbyhq/utils": "*",
    "@quimbyhq/agent": "*",
    "@quimbyhq/workspace": "*",
    "citty": "^0.1.6",
    "execa": "^9.6.1",
    "pathe": "^2.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@vitest/coverage-v8": "^3.2.6",
    "tsup": "*",
    "typescript": "*",
    "vitest": "^3.2.3"
  }
}
