{
  "name": "quimby-vscode",
  "displayName": "Quimby",
  "description": "Open resolved Quimby layouts as VS Code terminals.",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.95.0"
  },
  "activationEvents": [
    "onCommand:quimby.openLayout",
    "onCommand:quimby.connectWorkspace"
  ],
  "contributes": {
    "commands": [
      {
        "command": "quimby.openLayout",
        "title": "Quimby: Open Layout"
      },
      {
        "command": "quimby.connectWorkspace",
        "title": "Quimby: Connect Workspace"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "eslint src",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "*"
  }
}
