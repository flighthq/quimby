{
  "name": "quimby",
  "version": "0.2.0",
  "description": "Orchestrate multiple AI agents in isolated workers",
  "license": "MIT",
  "type": "module",
  "bin": {
    "quimby": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "citty": "^0.1.6",
    "consola": "^3.4.2",
    "execa": "^9.6.1",
    "pathe": "^2.0.3",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  }
}
