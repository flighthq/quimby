{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "noEmitOnError": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "lib": ["ES2022"],
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "paths": {
      "@quimbyhq/types": ["./packages/types/src/index.ts"],
      "@quimbyhq/types/*": ["./packages/types/src/*"],
      "@quimbyhq/errors": ["./packages/errors/src/index.ts"],
      "@quimbyhq/errors/*": ["./packages/errors/src/*"],
      "@quimbyhq/utils": ["./packages/utils/src/index.ts"],
      "@quimbyhq/utils/*": ["./packages/utils/src/*"],
      "@quimbyhq/paths": ["./packages/paths/src/index.ts"],
      "@quimbyhq/paths/*": ["./packages/paths/src/*"],
      "@quimbyhq/template": ["./packages/template/src/index.ts"],
      "@quimbyhq/template/*": ["./packages/template/src/*"],
      "@quimbyhq/git": ["./packages/git/src/index.ts"],
      "@quimbyhq/git/*": ["./packages/git/src/*"],
      "@quimbyhq/transport": ["./packages/transport/src/index.ts"],
      "@quimbyhq/transport/*": ["./packages/transport/src/*"],
      "@quimbyhq/runtimes": ["./packages/runtimes/src/index.ts"],
      "@quimbyhq/runtimes/*": ["./packages/runtimes/src/*"],
      "@quimbyhq/workspace": ["./packages/workspace/src/index.ts"],
      "@quimbyhq/workspace/*": ["./packages/workspace/src/*"],
      "@quimbyhq/worker": ["./packages/worker/src/index.ts"],
      "@quimbyhq/worker/*": ["./packages/worker/src/*"],
      "@quimbyhq/pack": ["./packages/pack/src/index.ts"],
      "@quimbyhq/pack/*": ["./packages/pack/src/*"],
      "@quimbyhq/server": ["./packages/server/src/index.ts"],
      "@quimbyhq/server/*": ["./packages/server/src/*"]
    }
  }
}
